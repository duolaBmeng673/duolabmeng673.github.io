---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout>
  <section class="home-hero hero-shell" data-reveal>
    <div class="hero-copy">
      <p class="eyebrow">Personal Knowledge Space</p>
      <p class="hero-persona">你好，我是杨雨飞。</p>
      <h1>清晰记录技术、系统与思考。</h1>
      <div class="hero-actions" data-reveal>
        <a class="button primary" href="/blog/">阅读文章</a>
        <a class="button secondary" href="/about/">个人详情</a>
      </div>
    </div>
    <div class="hero-sculpture" aria-hidden="true">
      <span class="sculpture-bloom"></span>
      <span class="sculpture-ribbon ribbon-far"></span>
      <span class="sculpture-ribbon ribbon-mid"></span>
      <span class="sculpture-ribbon ribbon-near"></span>
      <span class="sculpture-glint"></span>
    </div>
  </section>

  <section class="feature-band" aria-label="关注方向">
    <article data-reveal data-tilt>
      <span>01</span>
      <h2>Web Development</h2>
      <p>关注前端体验、静态站点、工程化和可维护的产品界面。</p>
    </article>
    <article data-reveal data-tilt>
      <span>02</span>
      <h2>Distributed Systems</h2>
      <p>记录系统设计、网络通信、可靠性和工程实践里的关键取舍。</p>
    </article>
    <article data-reveal data-tilt>
      <span>03</span>
      <h2>AI & Algorithms</h2>
      <p>整理模型应用、算法训练和安全视角下的问题分析。</p>
    </article>
  </section>

  <section class="section latest-section" data-reveal>
    <div class="section-heading">
      <p class="eyebrow">Latest Posts</p>
      <h2>最新文章</h2>
    </div>
    <div class="post-grid">
      {posts.map((post) => (
        <article class="post-card" data-reveal data-tilt>
          <p class="post-date">{post.data.pubDate.toLocaleDateString('zh-CN')}</p>
          <h3><a href={`/blog/${post.id}/`}>{post.data.title}</a></h3>
          <p>{post.data.description}</p>
          <div class="mini-tags">
            {post.data.tags.map((tag) => <span>{tag}</span>)}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
