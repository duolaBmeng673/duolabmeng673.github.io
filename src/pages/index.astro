---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout>
  <section class="home-hero">
    <p class="eyebrow">Personal Knowledge Space</p>
    <h1>把复杂问题整理成清晰的笔记。</h1>
    <p class="lead">
      一个面向工程、算法和 AI 学习的静态博客。这里会放项目复盘、技术笔记，以及那些值得慢慢想明白的问题。
    </p>
    <div class="hero-actions">
      <a class="button primary" href="/blog/">阅读文章</a>
      <a class="button secondary" href="/about/">个人详情</a>
    </div>
  </section>

  <section class="feature-band" aria-label="关注方向">
    <article>
      <span>01</span>
      <h2>Web 开发</h2>
      <p>关注前端体验、静态站点、工程化和可维护的产品界面。</p>
    </article>
    <article>
      <span>02</span>
      <h2>分布式系统</h2>
      <p>记录系统设计、网络通信、可靠性和工程实践里的关键取舍。</p>
    </article>
    <article>
      <span>03</span>
      <h2>AI 与算法</h2>
      <p>整理模型应用、算法训练和安全视角下的问题分析。</p>
    </article>
  </section>

  <section class="section latest-section">
    <div class="section-heading">
      <p class="eyebrow">Latest Posts</p>
      <h2>最新文章</h2>
    </div>
    <div class="post-grid">
      {posts.map((post) => (
        <article class="post-card">
          <p class="post-date">{post.data.pubDate.toLocaleDateString('zh-CN')}</p>
          <h3><a href={`/blog/${post.id}/`}>{post.data.title}</a></h3>
          <p>{post.data.description}</p>
          <div class="mini-tags">
            {post.data.tags.map((tag) => <span>{tag}</span>)}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
